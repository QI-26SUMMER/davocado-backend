# Copy to .env and fill in real values. .env is git-ignored — never commit secrets.

# --- Database (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/davocado
DB_USERNAME=davocado
DB_PASSWORD=changeme

# --- JPA ---
# local: update | production: validate
JPA_DDL_AUTO=update

# --- JWT (single access token, no refresh) ---
# Use a long, random secret (>= 32 bytes for HS256). Generate e.g.:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL=1209600   # 14 days (in seconds)

# --- Google Cloud Storage (avocado photos) ---
# Path to the service account key JSON. Keep it OUTSIDE the repo.
# Issue one with:
#   gcloud iam service-accounts keys create <path> \
#     --iam-account=davocado-backend@qi-2026summer.iam.gserviceaccount.com
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\you\.gcp\davocado-backend-key.json
# Private bucket holding raw/ and cropped/ images. Blank disables GCS (URLs come back null).
GCS_BUCKET=qi-2026summer-avocado-images
# How long a signed image URL stays valid.
GCS_SIGNED_URL_TTL_MINUTES=15

# --- App ---
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
